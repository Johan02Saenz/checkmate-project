<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="#1E1E1E"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:elevation="4dp">

                <Button
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="‹"
                    android:textSize="20sp"
                    android:textColor="#EAEAEA"
                    android:padding="0dp"
                    app:backgroundTint="#121212"
                    app:cornerRadius="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="♟"
                    android:textSize="22sp"
                    android:textColor="#3D5AFE"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Checkmate"
                    android:textColor="#EAEAEA"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"/>

            </LinearLayout>

            <!-- PAGE HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selecciona tu oponente"
                    android:textColor="#EAEAEA"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Elige un bot según su nivel ELO para ajustar tu entrenamiento."
                    android:textColor="#546E7A"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

            <!-- BOT CARDS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <!-- Bot 1 — Principiante -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#1E1E1E">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                        <TextView android:layout_width="56dp" android:layout_height="56dp"
                            android:text="🤖" android:textSize="32sp" android:gravity="center"
                            android:background="#1a237e"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🟢 Principiante" android:textColor="#81C784"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="2dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Bot 1" android:textColor="#EAEAEA"
                                android:textSize="15sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Agresivo, busca combinaciones cortas y tácticas"
                                android:textColor="#546E7A" android:textSize="12sp" android:layout_marginBottom="6dp"/>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="ELO" android:textColor="#546E7A" android:textSize="10sp"
                                    android:layout_marginEnd="6dp"/>
                                <ProgressBar android:layout_width="0dp" android:layout_height="6dp"
                                    android:layout_weight="1" style="?android:attr/progressBarStyleHorizontal"
                                    android:progress="40" android:progressTint="#4CAF50"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="920" android:textColor="#EAEAEA"
                                    android:textSize="12sp" android:textStyle="bold" android:layout_marginStart="8dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Bot 2 — Intermedio -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#1E1E1E">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                        <TextView android:layout_width="56dp" android:layout_height="56dp"
                            android:text="⚙️" android:textSize="32sp" android:gravity="center"
                            android:background="#37474F"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🟡 Intermedio" android:textColor="#FFB74D"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="2dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Bot 2" android:textColor="#EAEAEA"
                                android:textSize="15sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Fuerte en maniobras y presión a largo plazo"
                                android:textColor="#546E7A" android:textSize="12sp" android:layout_marginBottom="6dp"/>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="ELO" android:textColor="#546E7A" android:textSize="10sp"
                                    android:layout_marginEnd="6dp"/>
                                <ProgressBar android:layout_width="0dp" android:layout_height="6dp"
                                    android:layout_weight="1" style="?android:attr/progressBarStyleHorizontal"
                                    android:progress="62" android:progressTint="#FF9800"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="1450" android:textColor="#EAEAEA"
                                    android:textSize="12sp" android:textStyle="bold" android:layout_marginStart="8dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Bot 3 — Avanzado -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#1E1E1E">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                        <TextView android:layout_width="56dp" android:layout_height="56dp"
                            android:text="🧙" android:textSize="32sp" android:gravity="center"
                            android:background="#4a148c"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🔴 Avanzado" android:textColor="#EF9A9A"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="2dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Bot 3" android:textColor="#EAEAEA"
                                android:textSize="15sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Especialista en finales y técnica posicional"
                                android:textColor="#546E7A" android:textSize="12sp" android:layout_marginBottom="6dp"/>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="ELO" android:textColor="#546E7A" android:textSize="10sp"
                                    android:layout_marginEnd="6dp"/>
                                <ProgressBar android:layout_width="0dp" android:layout_height="6dp"
                                    android:layout_weight="1" style="?android:attr/progressBarStyleHorizontal"
                                    android:progress="78" android:progressTint="#F44336"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="1780" android:textColor="#EAEAEA"
                                    android:textSize="12sp" android:textStyle="bold" android:layout_marginStart="8dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Bot 4 — Experto -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#1E1E1E">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                        <TextView android:layout_width="56dp" android:layout_height="56dp"
                            android:text="🔮" android:textSize="32sp" android:gravity="center"
                            android:background="#880e4f"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="💜 Experto" android:textColor="#CE93D8"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="2dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Bot 4" android:textColor="#EAEAEA"
                                android:textSize="15sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Profundo cálculo, evita imprecisiones"
                                android:textColor="#546E7A" android:textSize="12sp" android:layout_marginBottom="6dp"/>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="ELO" android:textColor="#546E7A" android:textSize="10sp"
                                    android:layout_marginEnd="6dp"/>
                                <ProgressBar android:layout_width="0dp" android:layout_height="6dp"
                                    android:layout_weight="1" style="?android:attr/progressBarStyleHorizontal"
                                    android:progress="92" android:progressTint="#9C27B0"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="2020" android:textColor="#EAEAEA"
                                    android:textSize="12sp" android:textStyle="bold" android:layout_marginStart="8dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- BOTÓN JUGAR FIJO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnJugar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:text="⚔️ Jugar contra Bot 1"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="#3D5AFE"
        app:cornerRadius="16dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>